// {{ .rule }}
func (i *{{ .struct_name }}) _{{ .field_name }}_invalid_enum_{{ .index }}_() error {
	if i.{{ .field_name }} == nil {
		return nil
	}
	for _, v := range []{{ remove_ptr .field_type }}{{ .enum_value }} {
		if *i.{{ .field_name }} == v {
			return nil
		}
	}
	return errors.New(`invalid<enum>: {{ .struct_name }}.{{ .field_name }} must be in the {{ .enum_value }}`)
}
