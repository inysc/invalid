// {{ .rule }}
func (i *{{ .struct_name }}) _{{ .field_name }}_invalid_regex_{{ .index }}_() error {
	if i.{{ .field_name }} != nil && !regex_{{ .index }}.MatchString(*i.{{ .field_name }}) {
		return errors.New(`invalid<regex>: {{ .struct_name }}.{{ .field_name }} must conform to the regex<{{ .regex_value }}>`)
	}
	return nil
}
